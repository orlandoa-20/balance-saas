# ── BalanceU env ── copy to .env.local and fill in. NEVER commit .env.local.
# Only NEXT_PUBLIC_* values reach the browser. Use Stripe TEST keys in dev.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY   # server-only, secret

# Stripe (use sk_test_/pk_test_ in development)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs (Stripe → Products → Prices). Map the two products you created.
NEXT_PUBLIC_STRIPE_PRICE_PLUS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PLUS_ANNUAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM="BalanceU <hello@yourdomain.com>"

# AI coach (optional, Pro features) — latest Claude model
ANTHROPIC_API_KEY=sk-ant-xxx

# Error monitoring (optional)
SENTRY_DSN=
